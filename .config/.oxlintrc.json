{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "ignorePatterns": ["dist/**", "docs/**", "docs-dist/**"],
  "options": {
    "typeAware": true
  },
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/no-misused-spread": "off"
  },
  "env": {
    "builtin": true
  }
}
